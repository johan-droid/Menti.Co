# ==============================================================================
# Menti.Co Cloud-First Environment Configuration
# ==============================================================================

# --- Database (Neon / PostgreSQL) ---
DATABASE_URL=postgresql://user:password@subdomain.neon.tech/neondb?sslmode=require

# --- Vector Search (Qdrant Cloud) ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-api-key

# --- Full-Text Search (Elastic Cloud) ---
ES_URL=https://your-deployment.es.us-east-1.aws.found.io:9243
ES_API_KEY=your-api-key

# --- Message Broker (Upstash Redis) ---
UPSTASH_REDIS_URL=rediss://default:password@your-service.upstash.io:6379

# --- Object Storage (AWS S3 / MinIO) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=mentico-papers
AWS_REGION=us-east-1

# --- AI & LLM Configuration ---
# Set to 'ollama' for local or provide API keys for hosted providers
LLM_PROVIDER=ollama 
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=llama3:8b

# --- Frontend & API ---
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000
DEBUG=True
